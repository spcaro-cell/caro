# ShellCheck configuration
# Disable rules that generate pre-existing false positives in this project.
# Rule by rule rationale:

# SC1091 - Not following source. ShellCheck can't resolve sourced files at
#          analysis time; sourced paths are environment-dependent.
disable=SC1091

# SC2034 - Variable appears unused. Many variables are exported or used in
#          eval contexts that ShellCheck can't track statically.
disable=SC2034

# SC2155 - Declare and assign separately. Pervasive pattern in existing scripts;
#          addressed incrementally, not wholesale on first pass.
disable=SC2155

# SC2126 - Use grep -c instead of grep | wc -l. Stylistic preference only.
disable=SC2126

# SC2046 - Quote to prevent word splitting. Intentional in several places where
#          word-splitting is the desired behavior.
disable=SC2046

# SC2086 - Double quote to prevent globbing. Note-level warning; intentional in
#          several contexts.
disable=SC2086

# SC2016 - Expressions don't expand in single quotes. Intentional use of single
#          quotes to pass literal strings to echo/heredocs.
disable=SC2016

# SC2012 - Use find instead of ls. Pattern is safe in controlled contexts here.
disable=SC2012

# SC2028 - echo may not expand escape sequences. Platform-specific behavior that
#          is handled by the scripts intentionally.
disable=SC2028

# SC2129 - Consider using { } >> file. Stylistic; current pattern is clear.
disable=SC2129

# SC2139 - This expands when defined, not used. Intentional for alias definitions.
disable=SC2139

# SC2001 - See if you can use a variable instead of sed. Pattern is intentional.
disable=SC2001

# SC2153 - Variable may have different values. False positive in these contexts.
disable=SC2153

# SC2235 - Use -a/-o instead of && inside [[ ]]. Intentional pattern.
disable=SC2235

# SC2124 - Assigning an array to a string. Intentional in these scripts.
disable=SC2124
